<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_popup_rounded"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sobre o SafeTrack"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nossa Missão"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="O SafeTrack é um aplicativo desenvolvido com o objetivo de oferecer mais segurança e tranquilidade para grupos de pessoas em deslocamento.\n\nSeja em viagens, eventos, trajetos noturnos ou situações do dia a dia, o SafeTrack permite que cada membro do grupo acompanhe em tempo real a localização dos demais, garantindo que todos cheguem ao destino com segurança.\n\nCom uma interface simples e intuitiva, o app possibilita criar grupos privados, compartilhar posição com precisão e enviar alertas rápidos em caso de emergência. O projeto foi idealizado como parte de um trabalho acadêmico, buscando aplicar tecnologia de geolocalização a problemas reais de segurança e comunicação.\n\nO SafeTrack nasce com a missão de conectar pessoas e oferecer uma camada extra de proteção, reforçando o cuidado coletivo por meio da tecnologia."
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalhes"
            android:textSize="16sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Versão 2.5.0 (Build 202511)" />
        <TextView
            android:id="@+id/txtDeveloper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Desenvolvido por: Absolut5Devs"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Informações Legais"
            android:textSize="16sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/linkPrivacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Política de Privacidade"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:paddingVertical="4dp"/>
        <TextView
            android:id="@+id/linkTerms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Termos de Uso"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>